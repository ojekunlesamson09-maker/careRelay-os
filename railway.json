{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "npm-9_x"]
        },
        "install": {
          "cmds": ["cd backend && npm install"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && node src/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}